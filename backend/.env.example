PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/community-events
JWT_SECRET=your-super-secret-key

# Optional: OpenAI for Event Prep blueprints and group @ai chat.
# Without this, those features use built-in demo responses (no API calls).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
